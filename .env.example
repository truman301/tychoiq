# ----------------------------------------------------------------------------
# SourcePilot AI — environment variables
# Copy this file to `.env` and fill in values as needed.
# The MVP runs fully in MOCK mode with NO keys required.
# ----------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# PostgreSQL (production + local). Local default points at the docker-compose /
# local Postgres on 5432. On Railway/Render/Neon, paste the provided URL here.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tychoiq?schema=public"

# --- Auth (public multi-user mode) ------------------------------------------
# REQUIRED in production: a long random string that signs session cookies.
# Generate: `openssl rand -base64 48`  (or any 32+ char random string)
AUTH_SECRET="dev-insecure-secret-change-me"
# Public URL of the deployed app (used for absolute links/cookies).
APP_URL="http://localhost:3000"
# Set to "true" to disable public sign-up (invite-only / single-tenant).
DISABLE_SIGNUP="false"

# --- Runtime mode -----------------------------------------------------------
# When true (default), connectors and LLM calls use deterministic mock data so
# the app runs with no external API keys. Set to "false" to enable real
# connectors/LLM calls for any provider whose key is configured below.
MOCK_MODE="true"

# --- LLM provider -----------------------------------------------------------
# Provider abstraction: "mock" (default) | "anthropic" | "openai"
LLM_PROVIDER="mock"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Embeddings provider ----------------------------------------------------
# "mock" (default, deterministic, offline) | "openai"
EMBEDDINGS_PROVIDER="mock"
OPENAI_EMBEDDINGS_MODEL="text-embedding-3-small"

# --- Search API connectors (optional; mock used if absent) ------------------
BRAVE_SEARCH_API_KEY=""
SERPAPI_API_KEY=""
BING_SEARCH_API_KEY=""
GOOGLE_CSE_API_KEY=""
GOOGLE_CSE_CX=""

# --- Maps / local data connectors (optional) --------------------------------
GOOGLE_PLACES_API_KEY=""
MAPBOX_TOKEN=""
# Overpass (OpenStreetMap) needs no key; endpoint is configurable.
OVERPASS_API_URL="https://overpass-api.de/api/interpreter"

# --- Government / public dataset connectors (optional) ----------------------
# These have public endpoints; left as stubs in MVP with TODOs in the code.
CMS_PROVIDER_DATA_BASE="https://data.cms.gov/provider-data/api/1"
NPPES_API_BASE="https://npiregistry.cms.hhs.gov/api"

# --- Crawler / compliance ---------------------------------------------------
CRAWLER_USER_AGENT="SourcePilotAI/0.1 (+https://example.com/bot; compliance@example.com)"
CRAWLER_RESPECT_ROBOTS="true"
CRAWLER_MAX_PAGES_PER_DOMAIN="8"
CRAWLER_REQUESTS_PER_MINUTE_PER_DOMAIN="20"

# --- App ---------------------------------------------------------------------
# Single-user local dev identity (no auth in MVP).
DEFAULT_USER_EMAIL="truman301@gmail.com"
DEFAULT_USER_NAME="Local Admin"
